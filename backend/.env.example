# ── Database ──────────────────────────────────────────────────
# SQLite (development):
DATABASE_URL=sqlite:///./securetransact.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/securetransact

# ── JWT ───────────────────────────────────────────────────────
# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=ganti-dengan-string-acak-minimal-32-karakter
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────
# Pisahkan dengan koma jika lebih dari satu origin
CORS_ORIGINS=http://localhost:5173

# ── Midtrans Payment ──────────────────────────────────────────
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=False

# ── Rate Limiting ─────────────────────────────────────────────
LOGIN_MAX_ATTEMPTS=5

# ── Seed (password akun default saat python seed.py) ─────────
# Jika tidak di-set, password di-generate secara acak
ADMIN_SEED_PASSWORD=
KASIR_SEED_PASSWORD=
MANAJER_SEED_PASSWORD=
